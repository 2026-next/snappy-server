# Connect to PostgreSQL running on the same GCP VM as the app
# Example: postgresql://app_user:YOUR_PASSWORD@localhost:5432/snappy
DATABASE_URL="postgresql://app_user:YOUR_PASSWORD@localhost:5432/snappy"

# Direct connection to the same database. Used for migrations
DIRECT_URL="postgresql://app_user:YOUR_PASSWORD@localhost:5432/snappy"

JWT_ACCESS_SECRET="your-access-secret"
JWT_REFRESH_SECRET="your-refresh-secret"
JWT_ACCESS_EXPIRES_IN_SECONDS=900 # 15 minutes
JWT_REFRESH_EXPIRES_IN_SECONDS=604800 # 7 days

# OAuth providers
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"
GOOGLE_CALLBACK_URL="http://localhost:3000/auth/oauth/google/callback"

KAKAO_CLIENT_ID="your-kakao-client-id"
KAKAO_CLIENT_SECRET="your-kakao-client-secret"
KAKAO_CALLBACK_URL="http://localhost:3000/auth/oauth/kakao/callback"

# Frontend URL
FRONTEND_ORIGIN="http://localhost:5174"


# GCP Configuration
GCP_PROJECT_ID="snappy-idnumber"
GCP_STORAGE_BUCKET="your-bucket-name" #gcs bucket 이름?

# GCP 서비스 계정 키 파일의 경로 (프로젝트 루트에 저장 .gitignore)
GOOGLE_APPLICATION_CREDENTIALS="json file"
