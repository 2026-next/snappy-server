# Runtime DB URL (Cloud SQL PostgreSQL)
# Use this in application runtime.
# Example (Private IP):
# DATABASE_URL="postgresql://app_user:YOUR_PASSWORD@10.10.0.3:5432/snappy?schema=public&sslmode=require"
DATABASE_URL="postgresql://app_user:YOUR_PASSWORD@127.0.0.1:5432/snappy?schema=public"

# Direct DB URL for Prisma CLI tasks (migrate/introspect)
# In Cloud SQL setups this may be identical to DATABASE_URL,
# or a separate direct/private endpoint depending on your networking policy.
DIRECT_URL="postgresql://app_user:YOUR_PASSWORD@127.0.0.1:5432/snappy?schema=public"
